<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Schedule Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:hint="@string/schedule_name_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_schedule_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Schedule Type Tabs: Fixed / Rotating -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout_schedule_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:tabMode="fixed"
            app:tabGravity="fill">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/schedule_type_fixed" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/schedule_type_rotating" />

        </com.google.android.material.tabs.TabLayout>

        <!-- Fixed Days section -->
        <LinearLayout
            android:id="@+id/section_fixed_days"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/work_days_heading"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <ToggleButton android:id="@+id/toggle_mon"
                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                    android:textOn="M" android:textOff="M" android:checked="true" />
                <ToggleButton android:id="@+id/toggle_tue"
                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                    android:textOn="T" android:textOff="T" android:checked="true" />
                <ToggleButton android:id="@+id/toggle_wed"
                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                    android:textOn="W" android:textOff="W" android:checked="true" />
                <ToggleButton android:id="@+id/toggle_thu"
                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                    android:textOn="T" android:textOff="T" android:checked="true" />
                <ToggleButton android:id="@+id/toggle_fri"
                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                    android:textOn="F" android:textOff="F" android:checked="true" />
                <ToggleButton android:id="@+id/toggle_sat"
                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                    android:textOn="S" android:textOff="S" />
                <ToggleButton android:id="@+id/toggle_sun"
                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                    android:textOn="S" android:textOff="S" />

            </LinearLayout>

            <!-- Monthly Override Info -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSecondaryContainer">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:text="@string/monthly_override_info"
                    android:textSize="13sp" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Rotating section (simplified) -->
        <LinearLayout
            android:id="@+id/section_rotating"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSecondaryContainer">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:text="@string/rotating_schedule_info"
                    android:textSize="13sp" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Default Alarm Time -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/default_alarm_time"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <TimePicker
            android:id="@+id/time_picker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:timePickerMode="clock" />

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_schedule"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/action_save"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

    </LinearLayout>

</ScrollView>
